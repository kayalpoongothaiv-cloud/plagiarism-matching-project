if __name__ == "__main__":

    sample_text = (
        "String matching is fundamental in plagiarism detection. "
        "The KMP algorithm improves over naive string matching by using "
        "the failure function. String matching algorithms reduce redundant "
        "comparisons during pattern search. KMP achieves linear time "
        "complexity making it ideal for large-scale text analysis."
    )

    print("\n>>> KMP ALGORITHM — PLAGIARISM DETECTION <<<")
    print(f"\nDocument:\n{sample_text}")

    # Test 1: case-sensitive
    result = kmp_search(sample_text, "String matching", case_sensitive=True)
    display_results(result, sample_text)

    # Test 2: case-insensitive
    result2 = kmp_search(sample_text, "kmp", case_sensitive=False)
    display_results(result2, sample_text.lower())

    # Test 3: pattern not present
    result3 = kmp_search(sample_text, "blockchain")
    display_results(result3, sample_text)

    # Show LPS table construction demo
    print("  ── LPS Table Demo ──")
    demo_patterns = ["ABABCABAB", "AABCAAB", "PLAGIARISM"]
    for pat in demo_patterns:
        lps = build_lps(pat.lower())
        print(f"  Pattern : {pat}")
        print(f"  LPS     : {lps}\n")
